@inherits DisplayBase

<PageComponent Name="Assignable Value Display" EditingNode="Node">
    <Publish>
        @if(ComponentData is not null 
            && Node is not null)
        {
            if(Node.RequireAuth)
            {
                <AuthorizationHandler Settings="Node">
                    <Authorized>
                        @ComponentData.AuthorizedMarkup
                    </Authorized>
                    <NotAuthorized>
                        @ComponentData.UnAuthorizedMarkup
                    </NotAuthorized>
                </AuthorizationHandler>
            }
            else
            {
                @ComponentData.AuthorizedMarkup
            }
        }
        else
        {
            <em>Invalid component data registration.</em>
        }
    </Publish>
    <Configure>
        <PageComponentEditorSettingsNode Name="Value Configuration">

        </PageComponentEditorSettingsNode>
    </Configure>
</PageComponent>