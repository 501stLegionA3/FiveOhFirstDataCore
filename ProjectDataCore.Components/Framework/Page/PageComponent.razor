@if(IsEditingScope && Editing is not null)
{
	<div class="absolute group inset-0">
		@Editing

		@if (EditingNode is not null)
		{
			@*Editor Tools*@
			@if (EditingNode.Component is not null)
			{
				@*There is a component here, so we need to render component settings:
					- Settings wheel for opening the configuration panel
					- Delete component actions (removes just the component, not this node)
				*@

				#region Component Settings

				#endregion
			}

			@*The component needs some interactions no matter what is going on:
				- Split interactions (to split this Node into two nodes)
				- Merge interactions (to delete other components)
				- Delete interaction (to delete this component)
			*@

			#region Split
			<div class="w-full h-full relative z-10 group-hover:block block bg-slate-200/80">
				<div class="absolute inset-0 grid place-content-center"
					data-drag-container="@EditingNode.EditorKey">
					<ContextMenu class="dropzone h-8 w-8 z-20" Identifier="@EditingNode.EditorKey">
						<Element>
							<button class="h-full w-full material-symbols-rounded rounded-lg shadow-md bg-slate-400 cursor-grab text-white
								drag-item" data-drop-zone="@($"{EditingNode.EditorKey}-add_split")" data-item-type="split" draggable="true">
								splitscreen
							</button>
						</Element>
						<Popup>
							<div class="w-100 h-100 p-2 flex flex-col gap-2 bg-slate-300 rounded-lg shadow-md">
								<button class="button-util-action" @onclick="@(async () => await AddContextMenuSplitAsync("left"))">Split Left</button>
								<button class="button-util-action" @onclick="@(async () => await AddContextMenuSplitAsync("right"))">Split Right</button>
								<hr />
								<button class="button-util-action" @onclick="@(async () => await AddContextMenuSplitAsync("top"))">Split Up</button>
								<button class="button-util-action" @onclick="@(async () => await AddContextMenuSplitAsync("bottom"))">Split Down</button>
							</div>
						</Popup>
					</ContextMenu>

					<div class="@(DraggingSplitscreen ? "inset-0 flex" : "hidden") z-10 absolute flex-row">
						<div class="flex flex-none w-[15%] flex-col">
							<div class="flex-grow"></div>

							<div class="flex-none h-[60%] bg-blue-400 dropzone" 
								data-ref-id="@($"{EditingNode.EditorKey}-add_split")"
								data-drop-zone="@($"{EditingNode.EditorKey}-add_split")"
								data-item-type="left"></div>

							<div class="flex-grow"></div>
						</div>
						<div class="flex flex-grow flex-col">
							<div class="flex-none h-[20%] bg-blue-400 dropzone" 
								data-ref-id="@($"{EditingNode.EditorKey}-add_split")"
								data-drop-zone="@($"{EditingNode.EditorKey}-add_split")"
								data-item-type="top"></div>

							<div class="flex-grow"></div>

							<div class="flex-none h-[20%] bg-blue-400 dropzone" 
								data-ref-id="@($"{EditingNode.EditorKey}-add_split")"
								data-drop-zone="@($"{EditingNode.EditorKey}-add_split")"
								data-item-type="bottom"></div>
						</div>
						<div class="flex flex-none w-[15%] flex-col">
							<div class="flex-grow"></div>

							<div class="flex-none h-[60%] bg-blue-400 dropzone" 
								data-ref-id="@($"{EditingNode.EditorKey}-add_split")"
								data-drop-zone="@($"{EditingNode.EditorKey}-add_split")"
								data-item-type="right"></div>

							<div class="flex-grow"></div>
						</div>
					</div>
				</div>
			</div>
			#endregion

			#region Merge

			#endregion

			#region Delete

			#endregion
		}
	</div>

	@*Call the configure render builder. There should be no visible HTML to render.*@
	@if(IsConfiguring)
	{
		<div class="hidden">
			@Configure
		</div>
	}
}
else
{
	<div class="absolute inset-0">
		@Publish
	</div>
}