@inherits PopupMenuBase

<div class="absolute inset-0 z-40" @onclick="AbortMenu">
	<div class="w-full h-full relative">
		<div class="absolute p-2 rounded-md bg-slate-400 shadow-md z-50 transition-all ease-in-out duration-200 
			@(_displayReady ? "scale-100 opacity-100" : "scale-90 opacity-0")"
			style="@(_left ? "left" : "right"): @_xPos; @(_top ? "top" : "bottom"): @_yPos;">
			@Content
		</div>
	</div>
</div>